---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const recentPosts = allPosts.slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title="alexajuno"
  description="Giao's personal site — writing about building real projects as a developer."
>
  <!-- Hero -->
  <section class="pb-8 pt-8 sm:pb-12 sm:pt-12">
    <h1
      class="animate-fade-in-up text-4xl font-bold tracking-tight sm:text-5xl"
    >
      Hi, I'm Giao
    </h1>
    <p
      class="animate-fade-in-up delay-100 mt-4 max-w-lg text-lg leading-relaxed text-zinc-600 dark:text-zinc-400"
    >
      A developer who builds things and writes about the process. Less than a
      year in, figuring it out one project at a time.
    </p>
    <div class="animate-fade-in-up delay-200 mt-8 flex flex-wrap gap-4">
      <a
        href="/blog"
        class="inline-flex items-center rounded-lg bg-zinc-900 px-5 py-2.5 text-sm font-medium text-white transition-all hover:scale-[1.02] hover:bg-zinc-700 active:scale-[0.98] dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300"
      >
        Read the blog
      </a>
      <a
        href="/projects"
        class="inline-flex items-center rounded-lg border border-zinc-300 px-5 py-2.5 text-sm font-medium text-zinc-700 transition-all hover:scale-[1.02] hover:bg-zinc-100 active:scale-[0.98] dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800"
      >
        See projects
      </a>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="animate-fade-in-up border-t border-zinc-200 pt-12 dark:border-zinc-800">
    <h2 class="text-xl font-semibold tracking-tight">Recent Posts</h2>
    <ul class="mt-6 space-y-6">
      {
        recentPosts.map((post) => (
          <li class="animate-fade-in-up">
            <a
              href={`/blog/${post.id}`}
              class="group block"
            >
              <span class="font-medium text-zinc-900 transition-colors group-hover:text-accent-600 dark:text-zinc-100 dark:group-hover:text-accent-400">
                {post.data.title}
              </span>
              <time
                datetime={post.data.date.toISOString()}
                class="mt-1 block text-sm text-zinc-500 dark:text-zinc-500"
              >
                {formatDate(post.data.date)}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="/blog"
      class="mt-8 inline-flex items-center gap-1 text-sm font-medium text-accent-600 transition-colors hover:text-accent-500 dark:text-accent-400 dark:hover:text-accent-300"
    >
      View all posts
      <svg
        class="h-4 w-4"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
      </svg>
    </a>
  </section>
</BaseLayout>
