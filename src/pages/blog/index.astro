---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout title="Blog" description="Writing about building real projects as a developer.">
  <section class="pb-16 pt-8 sm:pb-20 sm:pt-12">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Blog</h1>
    <p class="mt-4 max-w-lg text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
      Writing about building things, lessons learned, and figuring it out along the way.
    </p>
  </section>

  <ul class="space-y-8">
    {
      posts.map((post) => (
        <li class="group border-b border-zinc-200 pb-8 last:border-0 dark:border-zinc-800">
          <a href={`/blog/${post.id}`} class="block">
            <h2 class="text-lg font-semibold text-zinc-900 transition-colors group-hover:text-violet-600 dark:text-zinc-100 dark:group-hover:text-violet-400">
              {post.data.title}
            </h2>
            <time
              datetime={post.data.date.toISOString()}
              class="mt-1 block text-sm text-zinc-500 dark:text-zinc-500"
            >
              {formatDate(post.data.date)}
            </time>
            {post.data.description && (
              <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                {post.data.description}
              </p>
            )}
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="inline-block rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
